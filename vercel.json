{
  "version": 2,
  "builds": [
    {
      "src": "bot.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "bot.py"
    },
    {
      "src": "/api/webhook",
      "dest": "bot.py"
    },
    {
      "src": "/api/cron",
      "dest": "bot.py"
    }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 19 * * *"
    }
  ]
}
